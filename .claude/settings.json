{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python -m pytest *)",
      "Bash(pytest *)",
      "Bash(python app.py)",
      "Bash(pip install *)",
      "Bash(pip freeze *)",
      "Bash(python -c *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  }
}
