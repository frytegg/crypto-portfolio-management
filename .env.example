# Application
APP_ENV=development
APP_LOG_LEVEL=info
APP_DEBUG=true
PORT=8050

# CoinGecko — register free demo key at https://www.coingecko.com/en/api
# Free tier: 30 calls/min, 10k calls/month
COINGECKO_API_KEY=

# Cache — persistent SQLite-backed disk cache
CACHE_DIR=.cache

# Binance WebSocket — no key needed (public streams only)
BINANCE_WS_ENABLED=true

# Portfolio defaults
DEFAULT_MAX_WEIGHT=0.15
DEFAULT_LOOKBACK_DAYS=730
TRANSACTION_COST_BPS=10
